# Required: Mandate will not answer meeting questions without this key.
# Create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Required: Deepgram provides both meeting transcription and the delegate voice.
# Create a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
DEEPGRAM_STT_MODEL=nova-3
# Optional for Nova-3: comma-separated terms that Deepgram should favor.
DEEPGRAM_KEYTERMS=Delegate

# Required for PDF reports. Create the .venv described in README.md, then keep this value.
REPORT_PYTHON=.venv/bin/python

# The optional Zoom audio route does not use a Zoom API, OAuth application, or Zoom key.
# See README.md for the local BlackHole setup.

PORT=4242
