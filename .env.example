# Required: Delegate will not answer meeting questions without this key.
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# All model-generated Delegate tasks use GPT-5.6 Luna with no reasoning tokens.
OPENAI_MODEL=gpt-5.6-luna
OPENAI_REASONING_EFFORT=none
# Used for semantic retrieval over approved references. The 768-dimension default
# preserves the prior in-memory index size while using OpenAI embeddings.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=768

# Required: Deepgram powers the live Zoom speech pipeline and Demo Mode voice.
# Create a key at https://console.deepgram.com/
DEEPGRAM_API_KEY=
# Attendee Zoom meetings use Deepgram Flux: low-latency turn detection plus raw streaming speech.
DEEPGRAM_STT_MODEL=flux-general-en
DEEPGRAM_TTS_MODEL=flux-alexis-en
DEEPGRAM_EOT_THRESHOLD=0.7
DEEPGRAM_EOT_TIMEOUT_MS=1800
# Demo Mode streams 16 kHz PCM from the browser to the same low-latency Flux APIs.
DEEPGRAM_BROWSER_STT_MODEL=flux-general-en
DEEPGRAM_BROWSER_TTS_MODEL=flux-alexis-en

# Required for Full Use Mode: Attendee joins Zoom and streams audio to Delegate.
# Create an API key and copy the Base64 webhook secret from Attendee Settings → Webhooks.
# Keep the secret exactly as shown, including any trailing /, +, or = characters.
ATTENDEE_API_KEY=
ATTENDEE_WEBHOOK_SECRET=
# A public HTTPS URL that reaches this Node server. Required because Attendee must
# call the webhook, voice-agent page, and (when enabled) screen-share page. Never use localhost.
# During local development, set this to your Cloudflare Tunnel URL.
PUBLIC_BASE_URL=

# Required when a meeting brief enables Delegate's live browser presentation.
# Create a Browserbase API key at https://www.browserbase.com/ and optionally set
# the project ID shown in the Browserbase dashboard. Browser sessions time out
# automatically; the default is 30 minutes and can be changed below.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_SESSION_TIMEOUT_SECONDS=1800
# Browserbase defaults to Oregon. Use Singapore for lower latency from Southeast Asia.
BROWSERBASE_REGION=ap-southeast-1
# Higher source resolution keeps text sharper after the live-view and Zoom stream.
BROWSERBASE_VIEWPORT_WIDTH=1920
BROWSERBASE_VIEWPORT_HEIGHT=1080

# Required for PDF reports. Create the .venv described in README.md, then keep this value.
REPORT_PYTHON=.venv/bin/python

# Also configure Attendee's own Zoom credentials and a transcription-provider key in
# its dashboard (Settings → Credentials). Those are kept by Attendee, not in this file.

PORT=4242
